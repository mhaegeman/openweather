# Copy to .env and fill in your values — never commit .env to version control

# SQLAlchemy connection string
# Format: mysql+pymysql://<user>:<password>@<host>/<schema>
DB_URL=mysql+pymysql://user:password@host/OpenWeather

# OpenWeather API key — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Comma-separated list of cities (optional, defaults shown)
CITIES=Dongen,Tilburg,Eindhoven
